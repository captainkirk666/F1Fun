<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Table Lab</title>

<h1>Table Lab</h1>

<p class="subtitle">
Building the Editorial Table Component
</p>

    <link rel="stylesheet" href="foundation/colours.css">
    <link rel="stylesheet" href="foundation/spacing.css">
    <link rel="stylesheet" href="foundation/padding.css">
    <link rel="stylesheet" href="foundation/borders.css">

    <link rel="stylesheet" href="components/card.css">

    <link rel="stylesheet" href="style.css">

</head>

<body>

    <div class="page">

        <div class="widget">

            <div class="widget-header">

                <h1> 2026 F1 Drivers Championship</h1>

                <p class="subtitle">
                    Current Driver Standings
                </p>

            </div>

<div class="card table-header">

    <div class="table-cell table-cell--center">POS</div>

    <div class="table-cell">DRIVER</div>

    <div class="table-cell">NATIONALITY</div>

    <div class="table-cell">TEAM</div>

    <div class="table-cell table-cell--right">PTS</div>

    <div class="table-cell table-cell--right">WINS</div>

</div>

<div id="table" class="table">

    <div class="card table-row">

        <div class="table-cell table-cell--center">
            1
        </div>

        <div class="table-cell">
            Andrea Kimi Antonelli
        </div>

        <div class="table-cell">
            Italian
        </div>

        <div class="table-cell">
            Mercedes
        </div>

        <div class="table-cell table-cell--right">
            204
        </div>

        <div class="table-cell table-cell--right">
            6
        </div>

    </div>

</div>

</div>

</div>

<script src="app.js"></script>

</body>

</html>
